# Public app URL used in NOWPayments redirects and webhook callback URLs.
NEXT_PUBLIC_APP_URL=https://gpt-store-custom-gpt.prin7r.com
NEXT_PUBLIC_SITE_URL=https://gpt-store-custom-gpt.prin7r.com

# NOWPayments — primary crypto rail (USDT/USDC + fiat partner card on-ramp).
# Live values live only in the deploy host's /opt/prin7r-deploys/<slug>/.env.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# Telegram — engagement-desk channel pings for concierge + IPN.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DESK_CHANNEL_ID=

# Postmark — transactional email for engagement-desk notifications.
POSTMARK_TOKEN=
POSTMARK_DESK_EMAIL=desk@gpt-store-custom-gpt.prin7r.com
POSTMARK_FROM_EMAIL=desk@gpt-store-custom-gpt.prin7r.com

# Phase 2 — Marketing analytics (SQLite orders database).
ORDERS_DB_DIR=/opt/prin7r-deploys/gpt-store-custom-gpt/data

# Phase 2 — Notion sync (optional, requires Notion integration).
NOTION_ORDERS_DSID=
PRIN7R_NOTION_TOKEN=

# Plisio — backup direct stablecoin invoice rail (not wired in landing yet).
PLISIO_API_KEY=

# Reown / WalletConnect — direct-wallet fallback (not wired in landing yet).
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Merchant settlement wallets (for Reown/direct-deposit fallbacks).
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=
